<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.test.withdayback.region.dao.RegionDao">

    <select id="getRegion" resultType="Region">
        select * from region
    </select>

    <select id="getRegionId" resultType="int">
        select region_id
        from region
        where region_name = #{regionName}
    </select>

    <select id="getDetailRegion" resultType="DetailRegion">
        select *
        from detail_region
        where region_id = #{regionId}
    </select>
</mapper>